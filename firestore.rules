rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safe Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'videopremieroficial@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/artists/$(request.auth.uid)) && get(/databases/$(database)/documents/artists/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Artist Profiles Rules ---
    match /artists/{userId} {
      allow get: if true; // Public profiles are read by fans
      allow list: if true; // To find and browse artists
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      // Musics (nested sub-collection)
      match /musics/{trackId} {
        allow get, list: if true; // Public listens to music
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin() || (
          // Allow viewers to increment playsCount/plays safely
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playsCount', 'plays', 'updatedAt'])
        );
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Analytics for each Artist (nested sub-collection)
      match /analytics/metrics {
        allow get, list: if true; // Read analytics
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin() || (
          // Allow viewers to increment viewsCount or whatsappClicks one by one safely without decreasing
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'whatsappClicks'])
        );
      }
    }

  }
}
