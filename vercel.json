{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/catalogo/:userId",
      "destination": "/api/metadata?userId=:userId&type=catalogo"
    },
    {
      "source": "/artista/:userId",
      "destination": "/api/metadata?userId=:userId&type=artista"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
