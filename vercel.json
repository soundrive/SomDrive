{
  "crons": [
    {
      "path": "/api/internal/process-expirations",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/s/:slug/repertorio/:repertoireId",
      "destination": "/api/metadata?slug=:slug&repertoireId=:repertoireId"
    },
    {
      "source": "/s/:slug",
      "destination": "/api/metadata?slug=:slug"
    },
    {
      "source": "/catalogo/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
